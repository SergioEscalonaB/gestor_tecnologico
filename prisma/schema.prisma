// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Modelo EMPLEADO
model Employee {
  id            Int       @id @default(autoincrement())
  nombre        String
  cargo         String
  area          String
  correo_electronico String   @unique
  
  asignaciones  Assignment[]
  
  @@map("empleados")
}

// Modelo ACTIVO
model Asset {
  id               Int       @id @default(autoincrement())
  nombre           String
  tipo             String
  marca            String
  modelo           String
  numero_serie     String       @unique
  estado           String       // disponible, en_uso, mantenimiento, dado_baja
  fecha_compra     DateTime     @map("fecha_compra")
  
  asignaciones     Assignment[]
  mantenimientos   Maintenance[]
  
  @@map("activos")
}

// Modelo ASIGNACION
model Assignment {
  id               Int       @id @default(autoincrement())
  activo_id        Int       
  empleado_id      Int       
  fecha_inicio     DateTime     @default(now())
  fecha_fin        DateTime?
  
  activo           Asset        @relation(fields: [activo_id], references: [id], onDelete: Restrict)
  empleado         Employee     @relation(fields: [empleado_id], references: [id], onDelete: Restrict)
  
  @@unique([activo_id, fecha_fin])
  @@index([activo_id])
  @@index([empleado_id])
  @@map("asignaciones")
}

// Modelo MANTENIMIENTO
model Maintenance {
  id               Int       @id @default(autoincrement())
  activo_id        Int       
  tipo             String       // preventivo, correctivo
  descripcion      String
  fecha            DateTime     @default(now())
  tecnico          String
  
  activo           Asset        @relation(fields: [activo_id], references: [id], onDelete: Cascade)
  
  @@index([activo_id])
  @@index([fecha])
  @@map("mantenimientos")
}