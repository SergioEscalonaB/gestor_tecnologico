// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Modelo EMPLEADO
model Employee {
  id                 Int          @id @default(autoincrement())
  nombre             String
  cargo              String
  area               String
  correo_electronico String       @unique
  
  asignaciones       Assignment[]
  activosResponsable Asset[]      @relation("EmpleadoResponsable")
  
  @@map("empleados")
}

// Modelo ACTIVO
model Asset {
  id                    Int          @id @default(autoincrement())
  nombre                String
  categoria             String
  marca                 String
  estado                String       // disponible, en_uso, mantenimiento, dado_baja
  ubicacion             String?
  modelo                String
  numero_serie          String       @unique
  fecha_compra          DateTime
  valor_compra          Decimal?
  proveedor             String?
  empleadoResponsableId Int?
  
  empleadoResponsable   Employee?    @relation("EmpleadoResponsable", fields: [empleadoResponsableId], references: [id])
  asignaciones          Assignment[]
  mantenimientos        Maintenance[]
  
  @@map("activos")
}

// Modelo ASIGNACION
model Assignment {
  id            Int      @id @default(autoincrement())
  activoId      Int
  empleadoId    Int
  fecha_inicio  DateTime @default(now())
  fecha_fin     DateTime?
  
  activo        Asset    @relation(fields: [activoId], references: [id], onDelete: Restrict)
  empleado      Employee @relation(fields: [empleadoId], references: [id], onDelete: Restrict)
  
  @@unique([activoId, fecha_fin])
  @@index([activoId])
  @@index([empleadoId])
  @@map("asignaciones")
}

// Modelo MANTENIMIENTO
model Maintenance {
  id                Int      @id @default(autoincrement())
  activoId          Int
  activo_nombre     String
  tipo              String   // preventivo, correctivo, revision_general, revision_de_software
  descripcion       String
  fecha_programada  DateTime
  responsable       String
  estado            String   // pendiente, en_proceso, programado, pendiente_de_respuesta, vencido
  
  activo            Asset    @relation(fields: [activoId], references: [id], onDelete: Cascade)
  
  @@index([activoId])
  @@index([fecha_programada])
  @@map("mantenimientos")
}